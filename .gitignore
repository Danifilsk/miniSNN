# Build local
/build/
/core/build/
*.exe
*.o
*.obj
*.out
*.dll
*.pdb
*.ilk

# Python
__pycache__/
*.pyc

# Dados temporarios de experimentos
tmp_*.csv

# Resultados reproduziveis dos exemplos publicos
/core/results/api/*.csv
/core/results/api/*.png

# Resultados recriaveis do demo interno
/core/results/internal_demo/*.csv
/core/results/internal_demo/*.png

# Resultados locais gerados pelo runner de cenarios
/core/results/scenarios/*
!/core/results/scenarios/.gitkeep

# Resultados locais gerados por comparacoes de cenarios
/core/results/comparisons/*
!/core/results/comparisons/.gitkeep

# Resultados locais da comparacao entre modelos neuronais
/core/results/model_comparison/*
!/core/results/model_comparison/.gitkeep

# Resultados locais de benchmark (recriaveis)
/core/results/benchmarks/*
!/core/results/benchmarks/.gitkeep

# Resultados locais gerados por neuroevolucao
/core/results/evolution/*
!/core/results/evolution/.gitkeep
